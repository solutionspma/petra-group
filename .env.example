# Profile flags for Document Depot (serverless function profile-flags.mjs)
# ---------------------------------------------------------------------------
# 1. Copy this file:  cp .env.example .env
# 2. Edit .env — uncomment / set only what you need (see REMOTE_IOS_INSTALL_VISIBILITY.txt)
# 3. Push to Netlify:
#      netlify login && netlify link
#      netlify env:import .env
#    Or: Netlify → Site configuration → Environment variables → Import from .env
#
# .env is gitignored; never commit real values.

# --- Option A: one JSON blob (several leaders at once) ---
# Use escaped quotes if your importer requires it:
# EMAIL_PROFILE_IOS_LIVE_JSON="{\"kevin-dickerson\":true}"
# Or single-line (works with many dotenv parsers):
# EMAIL_PROFILE_IOS_LIVE_JSON={"kevin-dickerson":true,"troy-dixon":true}

# --- Option B: one variable per leader (underscores in name = hyphens in leader id) ---
# EMAIL_IOS_LIVE_KEVIN_DICKERSON=1
# EMAIL_IOS_LIVE_TROY_DIXON=1

# Example (remove # to enable):
# EMAIL_IOS_LIVE_KEVIN_DICKERSON=1
