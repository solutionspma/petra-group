# Optional — My Drive (Supabase). Set these in Netlify → Environment variables
# so `npm run build` injects public client config into dist/js/supabase-runtime-config.js.
# RLS on Storage enforces privacy; anon key is designed to be public.

SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_DRIVE_BUCKET=tpg-private

# --- Netlify profile-flags function (optional) ---
# EMAIL_PROFILE_IOS_LIVE_JSON="{\"kevin-dickerson\":true}"
# EMAIL_IOS_LIVE_KEVIN_DICKERSON=1
